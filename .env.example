# ============================================================
# Samira Chat Bot - Environment Variables Template
# Developed by @MrLuffy12377 (D Luffy)
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real keys!

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# OpenRouter API Keys (comma-separated, get from https://openrouter.ai)
OPENROUTER_API_KEYS=key1,key2,key3

# OpenRouter Model (see https://openrouter.ai/models for available models)
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# Owner Telegram User ID
OWNER_ID=0

# Channel Link (for help menu)
CHANNEL_LINK=https://t.me/yourchannel

# Help Menu Photo URL
HELP_PHOTO_URL=https://i.imgur.com/5kF0c6P.jpg

# Blocked Users (comma-separated user IDs)
BLOCKED_USERS=

# Blocked Usernames (comma-separated, without @)
BLOCKED_USERNAMES=

# Blocked Groups (comma-separated group IDs)
BLOCKED_GROUPS=

# Blocked Group Names (comma-separated, case-insensitive)
BLOCKED_GROUP_NAMES=

# Spam Prevention Settings
MAX_MESSAGES_PER_MINUTE=5
MAX_SAME_MESSAGE_REPEATS=3
COOLDOWN_PERIOD=300
